# Postgres connection string (Neon, Supabase, Railway, or local Postgres all work)
DATABASE_URL="postgresql://user:password@host:5432/spinlog"

# NextAuth
# NOTE: Spotify now requires HTTPS redirect URIs, except for loopback
# addresses (127.0.0.1) which are allowed over HTTP. Use 127.0.0.1, not
# "localhost", for local development, or Spotify will reject the redirect.
NEXTAUTH_URL="http://127.0.0.1:3000"
NEXTAUTH_SECRET="run: openssl rand -base64 32"

# Spotify app credentials (create at https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# setlist.fm API key (optional — powers the "Concerts" page's search).
# Free for non-commercial use. Apply for one at https://api.setlist.fm/
# (requires a free setlist.fm account first). Approval isn't always
# instant. Without this set, concert search is disabled but manual concert
# entry still works fine.
SETLISTFM_API_KEY=""

# Last.fm API key (optional — powers importing scrobble history and loved
# tracks from Settings). Free, and unlike setlist.fm, approval is
# essentially instant. Get one at https://www.last.fm/api/account/create
# (requires a free Last.fm account first — no OAuth needed for this
# feature, since reading someone's public scrobble history only needs
# their username, not their login).
LASTFM_API_KEY=""

# Discogs API token (optional — powers the "Shelf" page for cataloging
# physical media). Free, generated instantly (no approval wait) from your
# Discogs account: log in, go to Settings > Developers, click "Generate
# new token". https://www.discogs.com/settings/developers
DISCOGS_TOKEN=""

# Secret used to authenticate Vercel's daily cron job that auto-syncs
# everyone's Spotify plays and liked songs (see vercel.json). Generate any
# random string of 16+ characters (e.g. from a password manager) and set
# the exact same value here and in Vercel's Environment Variables — Vercel
# automatically sends it as the Authorization header when it triggers the
# cron job.
CRON_SECRET=""
